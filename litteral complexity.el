
(defun letters-frequency (letter$)
  "Returns the relative frequency of letter letter$. Data source: https://mathcenter.oxford.emory.edu/site/math125/englishLetterFreqs/."
  (cond
    ((string= letter$ "e") 0.12702)
    ((string= letter$ "t") 0.09056)
    ((string= letter$ "a") 0.08167)
    ((string= letter$ "o") 0.07507)
    ((string= letter$ "i") 0.06966)
    ((string= letter$ "n") 0.06749)
    ((string= letter$ "s") 0.06327)
    ((string= letter$ "h") 0.06094)
    ((string= letter$ "r") 0.05987)
    ((string= letter$ "d") 0.04253)
    ((string= letter$ "l") 0.04025)
    ((string= letter$ "c") 0.02782)
    ((string= letter$ "u") 0.02758)
    ((string= letter$ "m") 0.02406)
    ((string= letter$ "w") 0.02360)
    ((string= letter$ "f") 0.02228)
    ((string= letter$ "g") 0.02015)
    ((string= letter$ "y") 0.01974)
    ((string= letter$ "p") 0.01929)
    ((string= letter$ "b") 0.01492)
    ((string= letter$ "v") 0.00978)
    ((string= letter$ "k") 0.00772)
    ((string= letter$ "j") 0.00153)
    ((string= letter$ "x") 0.00150)
    ((string= letter$ "q") 0.00095)
    ((string= letter$ "z") 0.00074)))
					; (describe-function 'letters-frequency)

(defun litteral-complexity (string$)
  "Returns the 'litteral complexity' score of English word in string$."
  (let (product letter$ factor)
    (setq product 1.0)
    (setq string$ (downcase string$))
    (dotimes (i (length string$))
      (setq letter$ (substring string$ i (1+ i)))
      (setq factor (letters-frequency letter$))
      (setq product (* product factor)))
    (/ (log (/ 1.0 product)) (log 26.0))))
; (describe-function 'litteral-complexity)
